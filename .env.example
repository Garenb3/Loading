# ============================================================
# BingeBoard Full-Stack Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# ── Backend (Server) Configuration ──────────────────────────
# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/bingeboard

# Server Port
PORT=5000

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_minimum_32_characters
JWT_EXPIRE=7d

# CORS Origins (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Node Environment
NODE_ENV=development

# ── Frontend (Vite) Configuration ──────────────────────────
# API Base URL (must match server CORS origins)
VITE_API_URL=http://localhost:5000/api

# Rate Limiting (requests per 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
